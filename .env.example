# Server (BFF proxy) configuration
# Requests to /api/* are forwarded to this backend URL.
BACKEND_URL=http://localhost:5000

# Optional: prepend a backend prefix after stripping /api from frontend requests.
# Example:
# - Frontend /api/users -> Backend /users when empty
# - Frontend /api/users -> Backend /api/users when BACKEND_PATH_PREFIX=/api
BACKEND_PATH_PREFIX=/api

# Optional server port for the BFF + static frontend
PORT=3000

# Optional frontend base (defaults to /api)
REACT_APP_API_BASE=/api
